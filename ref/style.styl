ancho-movil = 1px
ancho-tableta = 768px
ancho-escritorio = 992px
ancho-escritorio-amplio = 1280px

@import("https://cdnjs.cloudflare.com/ajax/libs/reseter.css/2.0.0/reseter.min.css")

media(rango, valor)
	@media only screen and ({rango}: valor)
		block

solo-movil()
	+media('max-width', ancho-tableta)
		block

desde-tablet()
	+media('min-width', ancho-tableta)
		block

desde-escritorio()
	+media('min-width', ancho-escritorio)
		block

desde-escritorio-amplio()
	+media('min-width', ancho-escritorio-amplio)
		block

:root
	--color-amarillo: #FDBA30
	--color-lila: #9501FC
	--color-celeste: #10B5FB
	--color-fuchsia: #FC00D5

body 
	min-height: 100vh
	background-color black
	color white
	
#pagina
	height: 100vh
	width auto
	max-width 100vw
	aspect-ratio 9 / 16
	margin-inline auto
	display flex
	flex-direction column
	align-items stretch
	background-color white
	color black
	font-size 2vh

	h1, h2, h3, h4 ,h5, h6
		text-wrap balance
		text-align center
		line-height 1.1
		color inherit
		margin 0
		font-weight 700
	
	h1
		font-size 7.2vh
	h2
		font-size 5rem
	h3
		font-size 3.6vh
	h4
		font-size 3.6vh
		font-weight 400

	p
		font-size 2.6vh
		margin 0

#encabezado
	background-color var(--color-amarillo)
	display flex
	justify-content space-between
	align-items center
	min-height 10vh
	padding 2.5vh
	gap 1vh

#principal
	flex 1 1 auto
	display flex
	flex-direction column

	> .contenido
	> .opciones
		flex 1 1 auto

#pie
	background-color var(--color-amarillo)
	color black
	display flex
	flex-direction column
	align-items center
	justify-content center
	min-height 10vh
	padding 2.5vh
	gap 1vh
	

.logo
	width auto

	img
		height 5vh


.contenido
	padding 2.5vh
	background-color grey
	display flex
	flex-direction column
	justify-content center
	align-items center
	

a
button
[type=button], 
[type=reset], 
[type=submit]
	padding .4em 1em
	font-size 3vh
	color black
	
	background-color var(--color-amarillo)
	border none
	text-decoration none
	cursor pointer
	display block
	box-sizing border-box
	min-height 10vh
	display flex
	justify-content center
	align-items center
	gap .5em
	font-weight 700

.grupo
	display flex
	flex-direction column
	justify-content stretch
	align-items stretch

	&.derecha
		text-align right
		align-items end
		


.panel
	display flex
	flex-direction column
	align-items stretch
	padding 2.5vh
	gap 1vh
	background-color white
	color black
	text-align center

	&.inverso
		background-color black
		color white
		

.opciones
	display grid
	grid-template-columns 1fr 1fr
	grid-template-rows 1fr 1fr
	list-style none
	margin 0

	.opcion
		display grid
		grid-template-rows 1fr auto
		justify-content stretch
		place-items center
		padding 2.5vh 1vh
		gap 1vh
		color white
		background-color black
		text-align center
		text-wrap balance
		font-size 2.5vh
		font-weight 700
		gap 1vh

		&:nth-child(1)
			background-color var(--color-lila)
		&:nth-child(2)
			background-color var(--color-celeste)
		&:nth-child(3)
			background-color var(--color-fuchsia)

		> span
			// margin-block-end auto
			align-self start

		> img
			width 12vh
			aspect-ratio 1
			height auto
			object-fit contain
			

		

.tiempo
	font-variant-numeric: tabular-nums lining-nums