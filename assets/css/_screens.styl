// ============================================
// Pantallas — timer
// ============================================
@require '_variables'

// Timer
.tiempo
  font-variant-numeric: tabular-nums lining-nums
  font-size: 3vh
  font-weight: 700

  &.urgente
    animation: parpadeo 0.5s ease-in-out infinite alternate

@keyframes parpadeo
  from
    opacity: 1
  to
    opacity: 0.5
