/* ============================================
   Trivia UPN — Estilos principales
   Basado en ref/style.styl
   ============================================ */

/* Fuentes Sharp Grotesk */
@font-face {
  font-family: 'Sharp Grotesk';
  src: url('/fonts/SharpGrotesk-Light15.woff2') format('woff2'),
       url('/fonts/SharpGrotesk-Light15.woff') format('woff');
  font-weight: 300;
  font-style: normal;
  font-display: swap;
}

@font-face {
  font-family: 'Sharp Grotesk';
  src: url('/fonts/SharpGrotesk-Book15.woff2') format('woff2'),
       url('/fonts/SharpGrotesk-Book15.woff') format('woff');
  font-weight: 400;
  font-style: normal;
  font-display: swap;
}

@font-face {
  font-family: 'Sharp Grotesk';
  src: url('/fonts/SharpGrotesk-Bold15.woff2') format('woff2'),
       url('/fonts/SharpGrotesk-Bold15.woff') format('woff');
  font-weight: 700;
  font-style: normal;
  font-display: swap;
}

@font-face {
  font-family: 'Sharp Grotesk';
  src: url('/fonts/SharpGrotesk-Black15.woff2') format('woff2'),
       url('/fonts/SharpGrotesk-Black15.woff') format('woff');
  font-weight: 900;
  font-style: normal;
  font-display: swap;
}

/* Variables de color UPN */
color-amarillo = #FDBA30
color-lila = #9501FC
color-celeste = #10B5FB
color-fuchsia = #FC00D5
color-negro = #000000
color-blanco = #FFFFFF
color-gris = #808080

/* Breakpoints */
ancho-movil = 1px
ancho-tableta = 768px
ancho-escritorio = 992px
ancho-escritorio-amplio = 1280px

/* Mixins de media query */
media(rango, valor)
  @media only screen and ({rango}: valor)
    {block}

solo-movil()
  +media('max-width', ancho-tableta)
    {block}

desde-tablet()
  +media('min-width', ancho-tableta)
    {block}

desde-escritorio()
  +media('min-width', ancho-escritorio)
    {block}

desde-escritorio-amplio()
  +media('min-width', ancho-escritorio-amplio)
    {block}

/* Reset */
*,
*::before,
*::after
  box-sizing: border-box
  margin: 0
  padding: 0

html
  font-size: 16px
  -webkit-text-size-adjust: 100%

body
  min-height: 100vh
  min-height: 100dvh
  background-color: color-negro
  color: color-blanco
  font-family: 'Sharp Grotesk', -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif
  display: flex
  justify-content: center
  align-items: center

/* Página principal — 9:16 aspect ratio */
#pagina
  height: 100vh
  height: 100dvh
  width: auto
  max-width: 100vw
  aspect-ratio: 9 / 16
  margin-inline: auto
  display: flex
  flex-direction: column
  align-items: stretch
  background-color: color-blanco
  color: color-negro
  font-size: 2vh
  overflow: hidden

  h1, h2, h3, h4, h5, h6
    text-wrap: balance
    text-align: center
    line-height: 1.1
    color: inherit
    margin: 0
    font-weight: 700

  h1
    font-size: 7.2vh

  h2
    font-size: 5vh

  h3
    font-size: 3.6vh

  h4
    font-size: 3.6vh
    font-weight: 400

  p
    font-size: 2.6vh
    margin: 0

/* Encabezado amarillo */
#encabezado
  background-color: color-amarillo
  display: flex
  justify-content: space-between
  align-items: center
  min-height: 10vh
  padding: 2.5vh
  gap: 1vh
  flex-shrink: 0

/* Logo UPN */
.logo
  display: flex
  align-items: center

  img
    height: 5vh
    width: auto

/* Grupo derecha (timer) */
.grupo
  display: flex
  flex-direction: column
  justify-content: stretch
  align-items: stretch

  &.derecha
    text-align: right
    align-items: end

  strong
    font-size: 1.8vh
    font-weight: 700
    letter-spacing: 0.05em

/* Área principal */
#principal
  flex: 1 1 auto
  display: flex
  flex-direction: column
  overflow: hidden

  > .contenido,
  > .opciones
    flex: 1 1 auto

/* Pie amarillo */
#pie
  background-color: color-amarillo
  color: color-negro
  display: flex
  flex-direction: column
  align-items: center
  justify-content: center
  min-height: 10vh
  padding: 2.5vh
  gap: 1vh
  flex-shrink: 0

/* Paneles */
.panel
  display: flex
  flex-direction: column
  align-items: stretch
  padding: 2.5vh
  gap: 1vh
  background-color: color-blanco
  color: color-negro
  text-align: center
  flex-shrink: 0

  &.inverso
    background-color: color-negro
    color: color-blanco

/* Contenido central */
.contenido
  padding: 2.5vh
  background-color: color-gris
  display: flex
  flex-direction: column
  justify-content: center
  align-items: center
  flex: 1

  img
    max-width: 100%
    max-height: 30vh
    object-fit: contain
    border-radius: 1vh

/* Botones */
button,
a,
[type="button"],
[type="reset"],
[type="submit"]
  padding: 0.4em 1em
  font-size: 3vh
  color: color-negro
  background-color: color-amarillo
  border: none
  text-decoration: none
  cursor: pointer
  display: flex
  justify-content: center
  align-items: center
  gap: 0.5em
  font-weight: 700
  font-family: 'Sharp Grotesk', sans-serif
  min-height: 10vh
  transition: filter 0.15s ease

  &:active
    filter: brightness(0.9)

.btn-completo
  width: 100%

/* Opciones — grid 2x2 */
.opciones
  display: grid
  grid-template-columns: 1fr 1fr
  grid-template-rows: 1fr 1fr
  list-style: none
  margin: 0
  flex: 1

  .opcion
    display: grid
    grid-template-rows: 1fr auto
    justify-content: stretch
    place-items: center
    padding: 2.5vh 1vh
    gap: 1vh
    color: color-blanco
    background-color: color-negro
    text-align: center
    text-wrap: balance
    font-size: 2.5vh
    font-weight: 700
    border: none
    cursor: pointer
    font-family: 'Sharp Grotesk', sans-serif
    transition: filter 0.15s ease
    min-height: 0

    &:active
      filter: brightness(0.85)

    &:nth-child(1)
      background-color: color-lila

    &:nth-child(2)
      background-color: color-celeste

    &:nth-child(3)
      background-color: color-fuchsia

    &:nth-child(4)
      background-color: color-negro

    > span
      align-self: start
      padding: 0 1vh

    > img
      width: 12vh
      aspect-ratio: 1
      height: auto
      object-fit: contain

/* Timer */
.tiempo
  font-variant-numeric: tabular-nums lining-nums
  font-size: 3vh
  font-weight: 700

  &.urgente
    color: color-fuchsia
    animation: parpadeo 0.5s ease-in-out infinite alternate

@keyframes parpadeo
  from
    opacity: 1
  to
    opacity: 0.5

/* Pantalla de resultados */
.resultado-icono
  font-size: 10vh
  margin: 2vh 0

.resultado-mensaje
  padding: 2.5vh
  text-align: center

  h1
    margin-bottom: 1vh

  h4
    margin-bottom: 0.5vh

/* Puntuaciones */
.puntuaciones-lista
  flex: 1
  overflow-y: auto
  padding: 2.5vh
  display: flex
  flex-direction: column
  gap: 1.5vh

.puntuacion-item
  display: flex
  align-items: center
  gap: 1.5vh
  padding: 1.5vh 2vh
  border-radius: 1vh
  font-size: 2.5vh
  font-weight: 700

  &.correcta
    background-color: color-lila
    color: color-blanco

  &.incorrecta
    background-color: color-negro
    color: color-blanco

.puntuacion-numero
  min-width: 4vh
  font-weight: 900

.puntuacion-icono
  font-size: 3vh

.puntuacion-tiempo
  margin-left: auto
  font-weight: 400
  font-variant-numeric: tabular-nums

/* Transiciones entre pantallas */
.slide-fade-enter-active
  transition: all 0.2s ease-out

.slide-fade-leave-active
  transition: all 0.15s ease-in

.slide-fade-enter-from
  opacity: 0
  transform: translateX(2vh)

.slide-fade-leave-to
  opacity: 0
  transform: translateX(-2vh)

/* Estado de carga */
.cargando-inicial
  display: flex
  flex-direction: column
  align-items: center
  justify-content: center
  min-height: 100vh
  gap: 2vh
  font-size: 3vh
  color: color-negro

.error-inicial
  display: flex
  flex-direction: column
  align-items: center
  justify-content: center
  min-height: 100vh
  gap: 2vh
  font-size: 3vh
  color: color-negro
