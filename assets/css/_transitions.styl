// ============================================
// Transiciones entre pantallas
// ============================================

// Page transitions — zoom + lateral slide (parallel, grid-based)
.page-enter-active,
.page-leave-active {
  transition: all 0.45s cubic-bezier(0.25, 0.1, 0.25, 1);
  grid-area: 1 / 1;
}

.page-enter-from {
  opacity: 0;
  transform: scale(1.03);
}

.page-leave-to {
  opacity: 0;
  transform: scale(0.97);
}

// Estados de carga / error
.cargando-inicial,
.error-inicial
  display: flex
  flex-direction: column
  align-items: center
  justify-content: center
  min-height: 100vh
  gap: 2vh
  font-size: 3vh
  color: color-negro
