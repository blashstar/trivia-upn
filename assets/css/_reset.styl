// ============================================
// Reset & base
// ============================================
@require '_variables'

*,
*::before,
*::after
  box-sizing: border-box
  margin: 0
  padding: 0

html
  font-size: 16px
  -webkit-text-size-adjust: 100%

body
  min-height: 100vh
  min-height: 100dvh
  background-color: color-negro
  color: color-blanco
  font-family: 'Sharp Grotesk', -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif
  display: flex
  justify-content: center
  align-items: center
