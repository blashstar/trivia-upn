// ============================================
// Layout — #pagina, #encabezado, #principal, #pie
// ============================================
@require '_variables'

// Página principal — 9:16 aspect ratio
#pagina
  height: 100vh
  height: 100dvh
  width: auto
  max-width: 100vw
  aspect-ratio: 9 / 16
  margin-inline: auto
  display: flex
  flex-direction: column
  align-items: stretch
  background-color: color-blanco
  color: color-negro
  font-size: 2vh
  overflow: hidden

  h1, h2, h3, h4, h5, h6
    text-wrap: balance
    text-align: center
    line-height: 1.1
    color: inherit
    margin: 0 auto
    font-weight: 700

  h1
    font-size: 7.2vh

  h2
    font-size: 5vh

  h3
    font-size: 3.6vh

  h4
    font-size: 3.6vh
    font-weight: 400

  p
    font-size: 2.6vh
    margin: 0

// Encabezado amarillo
#encabezado
  background-color: color-amarillo
  display: flex
  justify-content: space-between
  align-items: center
  min-height: 10vh
  padding: 2.5vh
  gap: 1vh
  flex-shrink: 0

// Logo UPN
.logo
  display: flex
  align-items: center

  img
    height: 5vh
    width: auto

// Grupo derecha (timer)
.grupo
  display: flex
  flex-direction: column
  justify-content: stretch
  align-items: stretch

  &.derecha
    text-align: right
    align-items: end

  strong
    font-size: 1.8vh
    font-weight: 700
    letter-spacing: 0.05em

// Área principal
#principal
  flex: 1 1 auto
  display: flex
  flex-direction: column
  overflow: hidden

  > .contenido,
  > .opciones
    flex: 1 1 auto

// Pie amarillo
#pie
  background-color: color-amarillo
  color: color-negro
  display: flex
  flex-direction: column
  align-items: center
  justify-content: center
  min-height: 10vh
  padding: 2.5vh
  gap: 1vh
  flex-shrink: 0
